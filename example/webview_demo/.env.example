# Faro Web collector URL for the React demo app.
# Get this from Frontend Observability > Your App > Web SDK Config.
# If left empty, telemetry is logged to the browser console instead.
VITE_FARO_COLLECTOR_URL=https://faro-collector-prod-us-central-0.grafana.net/collect/YOUR_WEB_API_KEY

# Service name that appears in Grafana Tempo alongside the Flutter app.
VITE_FARO_SERVICE_NAME=faro-flutter-webview-example
